const evolutionEngine = {
    updateTheme: function() {
        const date = new Date();
        const month = date.getMonth(); // 0-11
        const year = date.getFullYear();
        
        // Recursive Seed: Changes based on the specific month and year
        const seed = (month + 1) * year;
        
        // Generate Infinite Color Palette
        const hue = (seed * 137.5) % 360; // Golden Ratio distribution
        const primary = `hsl(${hue}, 50%, 50%)`;
        const darkBase = `hsl(${hue}, 60%, 5%)`;
        const accent = `hsl(${(hue + 180) % 360}, 70%, 50%)`;

        // Apply to the Website Document
        document.documentElement.style.setProperty('--primary', primary);
        document.documentElement.style.setProperty('--bg', darkBase);
        document.documentElement.style.setProperty('--accent', accent);
        
        console.log(`[AI Sleeping Agent] Evolution Complete for Month ${month + 1}.`);
    }
};

// Execute on every load to ensure the current month's look is active
window.onload = evolutionEngine.updateTheme;
