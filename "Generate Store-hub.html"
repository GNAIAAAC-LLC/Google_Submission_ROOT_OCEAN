<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SSGPT6 Store Hub — Global Deals Engine</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    :root{
      --bg:#050910;
      --panel:#0b1320;
      --border:rgba(0,255,204,0.25);
      --gold:#d4af37;
      --accent:#00ffcc;
      --accent2:#00ace6;
      --accent3:#ff00ff;
      --text:#e5f7ff;
      --muted:#9fb6c8;
    }
    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:Arial, sans-serif;
      background:var(--bg);
      color:var(--text);
    }
    .container{
      width:min(96%,1100px);
      margin:40px auto 60px;
    }
    h1{
      color:var(--accent);
      letter-spacing:3px;
      font-size:1.7rem;
      margin:0 0 6px;
      text-align:center;
    }
    .subtitle{
      text-align:center;
      font-size:0.85rem;
      color:var(--muted);
      margin-bottom:24px;
    }
    .geo-selector{
      text-align:center;
      margin:10px 0 24px;
    }
    .geo-selector button{
      background:#050f18;
      color:var(--text);
      border:1px solid rgba(0,255,204,0.35);
      border-radius:999px;
      padding:7px 16px;
      margin:0 4px 6px;
      font-size:0.8rem;
      cursor:pointer;
    }
    .geo-selector button.active{
      background:var(--accent);
      color:#021015;
      border-color:var(--accent);
    }
    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:18px;
      margin-top:10px;
    }
    .card{
      background:var(--panel);
      border:1px solid var(--border);
      border-radius:12px;
      padding:14px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      min-height:210px;
    }
    .card h3{
      margin:4px 0 6px;
      font-size:1rem;
      color:var(--accent2);
    }
    .card p{
      margin:0 0 10px;
      font-size:0.85rem;
      color:#d8e7f3;
      line-height:1.4;
    }
    .tag{
      display:inline-block;
      padding:3px 8px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,0.18);
      font-size:0.7rem;
      color:var(--muted);
      margin-bottom:8px;
    }
    .btn-external{
      display:inline-block;
      margin-top:auto;
      padding:7px 14px;
      border-radius:999px;
      background:var(--accent2);
      color:#021015;
      font-size:0.8rem;
      text-decoration:none;
      text-align:center;
      border:none;
    }
    .btn-external:hover{
      background:#27c9ff;
    }
    .section-title{
      margin-top:32px;
      font-size:1.05rem;
      letter-spacing:2px;
      color:var(--gold);
    }
    .legal{
      margin-top:28px;
      font-size:0.75rem;
      color:var(--muted);
      border-top:1px solid rgba(255,255,255,0.08);
      padding-top:12px;
    }
    .partner-box{
      margin-top:30px;
      padding:16px;
      border-radius:12px;
      background:#050f18;
      border:1px solid rgba(0,255,204,0.25);
      font-size:0.85rem;
    }
    .partner-box a{
      color:var(--accent);
      text-decoration:none;
      font-weight:bold;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>SSGPT6 STORE HUB</h1>
    <p class="subtitle">GLOBAL DEALS ENGINE · TINY AI · HOME ENERGY · FASHION · TOOLS</p>

    <div class="geo-selector">
      <button class="active" onclick="filterStore('US')">USA</button>
      <button onclick="filterStore('CA')">Canada</button>
      <button onclick="filterStore('EU')">Europe</button>
      <button onclick="filterStore('Global')">Global</button>
    </div>

    <h2 class="section-title">FEATURED DEALS</h2>
    <div id="product-grid" class="grid">
      <!-- USA -->
      <div class="card US">
        <span class="tag">USA · HOME ENERGY</span>
