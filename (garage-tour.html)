<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GNAIAAAC LLC | Virtual Garage Tour & Global Liquidation</title>
    <style>
        :root {
            --gold: #d4b15a;
            --matrix-green: #00ff41;
            --deep-space: #01050a;
            --alert-red: #ff3e3e;
        }

        body {
            background-color: var(--deep-space);
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .rainbow-text {
            background: linear-gradient(to right, #ef5350, #f48fb1, #7e57c2, #2196f3, #26c6da, #43a047, #eeff41, #f9a825, #ff5722);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
        }

        header {
            border-bottom: 2px solid var(--gold);
            padding: 30px;
            text-align: center;
            background: rgba(0, 0, 0, 0.8);
        }

        .tour-container {
            position: relative;
            width: 90%;
            max-width: 1200px;
            height: 600px;
            margin: 30px auto;
            border: 3px solid var(--gold);
            background: url('https://images.unsplash.com/photo-1590674899484-d5640e854abe?auto=format&fit=crop&q=80&w=1200') no-repeat center center;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 50px rgba(212, 177, 90, 0.2);
        }

        .inventory-hotspot {
            position: absolute;
            width: 40px;
            height: 40px;
            background: rgba(0, 255, 65, 0.4);
            border: 2px solid var(--matrix-green);
            border-radius: 50%;
            cursor: pointer;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 255, 65, 0.7); }
            70% { transform: scale(1.2); box-shadow: 0 0 0 15px rgba(0, 255, 65, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 255, 65, 0); }
        }

        .sidebar {
            position: fixed;
            right: 20px;
            top: 150px;
            width: 280px;
            background: rgba(5, 15, 25, 0.9);
            border: 1px solid var(--gold);
            padding: 20px;
            border-radius: 10px;
        }

        .btn-buy {
            background: var(--gold);
            color: black;
            border: none;
            padding: 10px 20px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            margin-top: 10px;
        }

        .footer-legal {
            background: #000;
            padding: 40px;
            font-size: 11px;
            color: #888;
            border-top: 1px solid #222;
            line-height: 1.6;
        }

        .ghost-watch {
            color: var(--alert-red);
            font-size: 12px;
            text-align: center;
            margin-top: 10px;
            font-family: monospace;
        }
    </style>
</head>
<body>

