<section class="container" style="background: #030812; border: 1px solid var(--accent); padding: 40px;">
    <h2 style="color: var(--primary);">AUTHENTICATED INVESTMENT ANALYTICS</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
        <div class="card">
            <h4>Global GDP Impact</h4>
            <div id="gdp-val" style="font-size: 2rem; color: #00ff00;">+8.4% (Real)</div>
        </div>
        <div class="card">
            <h4>Dollar Devaluation Risk</h4>
            <div id="risk-val" style="font-size: 2rem; color: #ff0000;">0.02% (Low)</div>
        </div>
    </div>
    <button onclick="runDeepAudit()" class="btn-action">RUN DEEP LEARNING PROBABILITY CHECK</button>
</section>
